        "content": "import math\n\nfrom priorityQueue import PriorityQueue\n\n\ndef a_star(graph, start, goal, heuristic):\n    '''\n    A* shortest path search on a weighted graph.\n\n    Inputs:\n    [graph]: graph.Graph object. Edge weights are read from\n             edge.element() and must be non-negative numbers.\n    [start]: graph.Vertex source vertex (instance of graph)\n    [goal]: graph.Vertex target vertex (instance of graph)\n    [heuristic]: callable taking a graph.Vertex and returning a\n                 non-negative numeric estimate of the distance from\n                 that vertex to goal. Must be admissible for the\n                 returned path to be optimal.\n\n    Outputs:\n    [path]: list of vertices [start, ..., goal] forming the shortest\n            path, or None if goal is not reachable from start.\n    [length]: total weight of path, or math.inf if unreachable.\n    '''\n\n    g_score = {vertex: math.inf for vertex in graph.vertices()}\n    g_score[start] = 0\n    predecessor = {vertex: None for vertex in graph.vertices()}\n\n    open_set = PriorityQueue()\n    open_set.add(start, heuristic(start))\n\n    while True:\n        try:\n            current = open_set.pop()\n        except KeyError:\n            # open set exhausted without reaching goal\n            return None, math.inf\n\n        if current == goal:\n            path = [current]\n            while predecessor[current] is not None:\n                current = predecessor[current]\n                path.insert(0, current)\n            return path, g_score[goal]\n\n        for edge in graph.incident_edges(current, outgoing=True):\n            neighbor = edge.opposite(current)\n            tentative_g = g_score[current] + edge.element()\n            if tentative_g < g_score[neighbor]:\n                # relaxation step; PriorityQueue.add does decrease-key\n                g_score[neighbor] = tentative_g\n                predecessor[neighbor] = current\n                open_set.add(neighbor, tentative_g + heuristic(neighbor))\n\n\nif __name__ == '__main__':\n\n    import graph\n\n    # 4-node weighted directed example. Heuristic is the trivially\n    # admissible zero heuristic, so A* degenerates to Dijkstra here.\n    G = graph.Graph(directed=True)\n    vertices = {label: G.insert_vertex(label) for label in ('a', 'b', 'c', 'd')}\n    for source, dest, weight in [('a', 'b', 1), ('a', 'c', 4),\n                                 ('b', 'c', 2), ('b', 'd', 5),\n                                 ('c', 'd', 1)]:\n        G.insert_edge(vertices[source], vertices[dest], weight)\n\n    path, length = a_star(G, vertices['a'], vertices['d'], lambda _: 0)\n    print('Shortest path length: ' + str(length))\n    print('Path: ' + '->'.join(v.element() for v in path))\n",
